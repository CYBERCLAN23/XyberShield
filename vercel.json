{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "*.{html,json}",
      "use": "@vercel/static"
    },
    {
      "src": "style/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "animation/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "images/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp|json))$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/$1"
    },
    {
      "src": "^/(login|reset-password|report|education|index)(?:\\.html)?/?$",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "ignore": [
    "package.json",
    "package-lock.json",
    "node_modules/**"
  ]
}
