# Git LFS Configuration for XyberShield Media Files

# Videos
media/videos/*.mp4 filter=lfs diff=lfs merge=lfs -text
media/videos/*.webm filter=lfs diff=lfs merge=lfs -text
media/videos/*.mov filter=lfs diff=lfs merge=lfs -text
media/videos/*.avi filter=lfs diff=lfs merge=lfs -text

# PDFs
media/pdfs/*.pdf filter=lfs diff=lfs merge=lfs -text

# Large Images
media/images/infographies/*.png filter=lfs diff=lfs merge=lfs -text
media/images/infographies/*.jpg filter=lfs diff=lfs merge=lfs -text
media/images/infographies/*.jpeg filter=lfs diff=lfs merge=lfs -text
